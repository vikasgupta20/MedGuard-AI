{
    "rewrites": [
        {
            "source": "/dashboard",
            "destination": "/dashboard.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)\\.js",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/javascript"
                }
            ]
        }
    ]
}